# Use Ubuntu 22.04 as base image
FROM --platform=linux/arm64 ubuntu:22.04

# Set environment variables
ENV DEBIAN_FRONTEND=noninteractive
ENV GRPC_PYTHON_IMPLEMENTATION=rust
ENV CC=gcc
ENV CXX=g++

# Install system dependencies
RUN apt-get update && apt-get install -y \
    build-essential \
    cmake \
    git \
    curl \
    wget \
    python3 \
    python3-pip \
    python3-dev \
    pkg-config \
    libssl-dev \
    libffi-dev \
    libz-dev \
    unzip \
    gcc \
    g++ \
    && rm -rf /var/lib/apt/lists/*

# Install Rust toolchain
RUN curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | sh -s -- -y
ENV PATH="/root/.cargo/bin:${PATH}"

# Install Bazel for ARM64 - use version 8.0.1 for workspace compatibility
RUN mkdir -p /usr/local/bin \
    && curl -fsSL https://github.com/bazelbuild/bazel/releases/download/8.0.1/bazel-8.0.1-linux-arm64 -o /usr/local/bin/bazel \
    && chmod +x /usr/local/bin/bazel

# Set working directory
WORKDIR /workspace

# Copy the gRPC source code
COPY . .

# Create a custom bazel.rc that works with Bazel 8 by removing the problematic option
RUN cp tools/bazel.rc tools/bazel.rc.backup && \
    sed '/--enable_workspace=true/d' tools/bazel.rc.backup > tools/bazel.rc

# Test command - run Python tests with better error handling
CMD ["bash", "-c", "echo 'Starting Bazel test...' && echo 'Available memory:' && free -h && echo 'Available disk space:' && df -h && echo 'Checking compiler:' && which gcc && gcc --version && echo 'Syncing Bazel workspace...' && timeout 300 bazel sync --configure || echo 'Bazel sync failed, continuing...' && echo 'Running Python tests...' && timeout 1800 bazel test --cache_test_results=no --test_timeout=300 --local_test_jobs=1 --verbose_failures --show_timestamps '//src/python/...' --test_output=all || (echo 'Test failed, trying to get more info...' && bazel info && exit 1) && echo 'Test completed successfully!'"]
