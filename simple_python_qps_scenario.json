{
  "scenarios": [{
    "name": "python_simple_unary_test",
    "num_servers": 1,
    "num_clients": 1,
    "warmup_seconds": 2,
    "benchmark_seconds": 5,
    "spawn_local_worker_count": -2,
    "client_config": {
      "client_type": "SYNC_CLIENT",
      "security_params": null,
      "outstanding_rpcs_per_channel": 1,
      "client_channels": 1,
      "async_client_threads": 1,
      "rpc_type": "UNARY",
      "histogram_params": {
        "resolution": 0.01,
        "max_possible": 60000000000.0
      },
      "payload_config": {
        "simple_params": {
          "req_size": 0,
          "resp_size": 0
        }
      },
      "load_params": {
        "closed_loop": {}
      }
    },
    "server_config": {
      "server_type": "ASYNC_SERVER",
      "security_params": null,
      "async_server_threads": 1,
      "payload_config": {
        "simple_params": {
          "req_size": 0,
          "resp_size": 0
        }
      }
    }
  }]
}

