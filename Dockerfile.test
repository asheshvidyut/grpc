# Use Ubuntu 22.04 as base image
FROM ubuntu:22.04

# Set environment variables
ENV DEBIAN_FRONTEND=noninteractive
ENV GRPC_PYTHON_IMPLEMENTATION=rust

# Install system dependencies
RUN apt-get update && apt-get install -y \
    build-essential \
    cmake \
    git \
    curl \
    wget \
    python3 \
    python3-pip \
    python3-dev \
    pkg-config \
    libssl-dev \
    libffi-dev \
    libz-dev \
    gcc \
    g++ \
    && rm -rf /var/lib/apt/lists/*

# Set C compiler environment variables
ENV CC=gcc
ENV CXX=g++

# Install Rust
RUN curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | sh -s -- -y
ENV PATH="/root/.cargo/bin:${PATH}"

# Install Bazel
RUN mkdir -p /usr/local/bin && curl -fsSL https://github.com/bazelbuild/bazel/releases/download/8.0.1/bazel-8.0.1-linux-arm64 -o /usr/local/bin/bazel && chmod +x /usr/local/bin/bazel

# Set working directory
WORKDIR /workspace

# Copy the gRPC source code
COPY . .

# Build and test
CMD ["bash", "-c", "echo 'Starting Bazel test...' && echo 'Available memory:' && free -h && echo 'Available disk space:' && df -h && echo 'Checking compiler:' && which gcc && gcc --version && echo 'Building Rust extension...' && cd src/python/grpcio/grpc/_rust && cargo build --release && ls -la target/release/ && cp target/release/libgrpc_rust_bindings.so grpc_rust_bindings.so && ls -la grpc_rust_bindings.so && echo 'Testing Rust extension import...' && python3 -c 'import grpc_rust_bindings; print(\"Rust extension imported successfully!\")' || echo 'Rust extension not available, using Python stub' && cd /workspace && echo 'Cleaning Bazel cache...' && rm -rf /root/.cache/bazel && echo 'Syncing Bazel workspace...' && timeout 300 bazel sync --configure || echo 'Bazel sync failed, continuing...' && echo 'Running Python tests...' && timeout 1800 bazel test --cache_test_results=no --test_timeout=300 --local_test_jobs=1 --verbose_failures --show_timestamps '//src/python/...' --test_output=all || (echo 'Test failed, trying to get more info...' && bazel info && exit 1) && echo 'Test completed successfully!'"]
